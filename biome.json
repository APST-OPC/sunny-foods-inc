{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!biome.json",
			"!eslint.config.js",
			"!package.json",
			"!tsconfig.json",
			"!tsconfig.app.json",
			"!tsconfig.node.json",
			"!vite.config.ts",
			"!!**/dist"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 2,
		"lineWidth": 80,
		"lineEnding": "lf"
	},

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useButtonType": "off",
				"useKeyWithClickEvents": "off",
				"useSemanticElements": "off"
			},
			"style": {
				"useCollapsedElseIf": "error",
				"useConsistentArrayType": "error",
				"useConsistentCurlyBraces": "error",
				"useForOf": "error",
				"useImportType": "error"
			},
			"suspicious": {
				"noAlert": "error",
				"noArrayIndexKey": "off"
			},
			"correctness": {
				"noUndeclaredVariables": "error",
				"noUnusedVariables": "error",
				"noUnusedImports": "error"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"javascript": {
		"formatter": {
			"jsxQuoteStyle": "double",
			"bracketSameLine": true,
			"bracketSpacing": true,
			"arrowParentheses": "always"
		}
	},
	"json": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab",
			"trailingCommas": "none"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							{
								"type": true,
								"source": ["**", ":PACKAGE:", ":NODE:", ":ALIAS:", "~/**"]
							},
							":BLANK_LINE:",
							[":PACKAGE:", ":NODE:"],
							":BLANK_LINE:",
							["~/assets/**"],
							":BLANK_LINE:",
							["~/components/ui/**", "~/components/**"],
							":BLANK_LINE:",
							["~/pages/**"],
							":BLANK_LINE:",
							["~/**"],
							":BLANK_LINE:"
						]
					}
				}
			}
		}
	}
}
